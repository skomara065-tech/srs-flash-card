rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) || 
        request.auth.token.email == 'skomara065@gmail.com' || 
        request.auth.uid == '5k7EizMWHWQFp5S7MiSvphsFYhj2'
      );
    }

    // --- Admin Users ---
    match /admin_users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // --- Admin Decks ---
    match /admin_decks/{deckId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Admin Folders ---
    match /admin_folders/{folderId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Decks ---
    function isValidDeck(data) {
      return data.keys().hasAll(['userId', 'title']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100;
      // Removed `data.userId == request.auth.uid` check from validation so admin can create decks for users
    }

    match /decks/{deckId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid) && isValidDeck(request.resource.data);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) && 
                    isValidDeck(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'description', 'cardCount', 'tags', 'updatedAt', 'folderId', 'parentId', 'srsMode', 'dueCounts', 'adminDeckId']);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // --- Folders ---
    function isValidFolder(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100;
    }

    match /folders/{folderId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid) && isValidFolder(request.resource.data);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) && 
                    isValidFolder(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'updatedAt', 'parentId', 'adminFolderId']);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // --- Cards ---
    function isValidCard(data) {
      return data.keys().hasAll(['deckId', 'front', 'back']) &&
             data.deckId is string &&
             data.front is string && data.front.size() > 0 && data.front.size() <= 400 &&
             data.back is string && data.back.size() > 0 && data.back.size() <= 1000;
    }

    function ownsDeck(deckId) {
      let docSnap = get(/databases/$(database)/documents/decks/$(deckId));
      return docSnap != null && docSnap.data.userId == request.auth.uid;
    }

    match /decks/{deckId}/cards/{cardId} {
      allow list, get: if isSignedIn() && (isAdmin() || ownsDeck(deckId));
      allow create: if isSignedIn() && (isAdmin() || ownsDeck(deckId)) && isValidCard(request.resource.data);
      allow update: if isSignedIn() && (isAdmin() || ownsDeck(deckId)) && isValidCard(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['front', 'back', 'nextReview', 'interval', 'easeFactor', 'repetitionCount', 'lastRating', 'updatedAt', 'progress']);
      allow delete: if isSignedIn() && (isAdmin() || ownsDeck(deckId));
    }
  }
}
